{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health/",
    "healthcheckTimeout": 30
  },
  "watch": {
    "patterns": [
      "**/*.py",
      "requirements.txt",
      "Dockerfile",
      "templates/**/*.html",
      "static/**/*"
    ],
    "enabled": true
  }
}
