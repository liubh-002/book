# ============================================
# Pet Wash System — 环境变量配置模板
# 复制此文件为 .env 并填入实际值后使用
# ============================================

# Django 密钥（生产环境务必使用高强度随机字符串）
DJANGO_SECRET_KEY=your-secret-key-here

# 调试模式（生产环境设为 False）
DJANGO_DEBUG=False

# 允许的主机名（逗号分隔，Railway 会自动生成域名）
DJANGO_ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1

# CSRF 信任来源（逗号分隔，填入你的 Railway 域名）
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.railway.app

# PostgreSQL 数据库连接（Railway 会自动注入此变量）
DATABASE_URL=postgres://user:password@host:5432/pet_wash_system
